# ══════════════════════════════════════════════════════════════
#  HireVision AI — Variables d'environnement (root)
#  ⚠  Copier ce fichier en .env et remplir vos valeurs.
#  ⚠  Ne JAMAIS commiter .env dans Git !
# ══════════════════════════════════════════════════════════════

# ── Base de données MySQL ──────────────────────────────────
DB_USERNAME=root
DB_PASSWORD=

# ── JWT (générer une chaîne aléatoire sécurisée ≥ 64 cars) ─
# Exemple : openssl rand -hex 64
JWT_SECRET=change_me_with_a_long_random_secret_minimum_64_chars
JWT_EXPIRATION=3600000

# ── Google OAuth2 (Google Cloud Console) ──────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Email (compte Gmail + App Password) ───────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_16chars

# ── URL Frontend (angular) ─────────────────────────────────
FRONTEND_URL=http://localhost:4200

# ── Groq AI (service IA FastAPI) ──────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b
AI_SERVICE_URL=http://localhost:8000
